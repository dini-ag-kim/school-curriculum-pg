}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002151",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Ist ein Lehrplanelement, das in MV nur im Fach Deutsch in der Sek I vorkommt. \n\nHat die Funktion einer Lerninhaltsbeschreibung, liefert Beispiele zur Umsetzung der zuvor beschriebenen Kompetenzen.\n\nGrenzt sich zu \"Konkretisierung der Standards (MV)\" dadurch ab, dass es sich hierbei nicht um ein Lehrplanfragment handelt, welches eine Strukturierungsfunktion hat."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Konkretisierung (MV)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000332"
  }, {
    "@id" : "_:genid4177"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002153",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "KMK-Bildungsstandard (MV)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000263"
  }, {
    "@id" : "_:genid4181"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "Bisher nur in Fach Deutsch, Schulstufe Sek II gefunden. Ist gleichzusetzen mit Kompetenzen."
  } ]
}, {
