  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Das “Hauptschulniveu” ist ein “Bildungsgangniveau”, welches das Niveau des Hauptschulbildungsgangs beschreibt. \nEs beschreibt in welcher Tiefe und mit welchem Anspruch die Lerninhalte und Kompetenzen innerhalb dieses Bildungsgangs behandelt werden."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
