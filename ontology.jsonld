  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Schulstufe der Grundschule. Mit dem Beginn der Schulpflicht treten die Schülerinnen und Schüler in die gemeinsame Grundschule ein, die von der ersten bis zur vierten, in Berlin und Brandenburg bis zur sechsten Jahrgangsstufe reicht."
  } ],
