}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001445",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Lerninhalt (BE)"
  }, {
    "@language" : "en",
    "@value" : "learning content (BE)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000332"
  }, {
    "@id" : "_:genid1067"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@value" : "Inhalt (BE)"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Learning content that is taught as part of teaching. The learning content can be linked to competences that the learner can acquire while learning the content."
  }, {
    "@language" : "de",
    "@value" : "Lerninhalt der im Rahmen des Unterrichts vermittelt wird. Der Lerninhalt kann mit Kompetenzen verknüpft sein, die die lernende Person beim Lernen des Inhalts erlangen kann."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001446",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Lernmaterial (BE)"
  }, {
    "@language" : "en",
    "@value" : "learning material (BE)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid1071"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "de",
    "@value" : "Konkrete Mittel (z.B. in Form von Dokumenten), um bestimmte Kompetenzen zu erlernen."
  }, {
    "@language" : "en",
    "@value" : "Some concrete means (e.g. in form of documents) to acquire particular competences."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001447",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "operationalisierbar und meßbar"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Standard (BE)"
  }, {
    "@language" : "en",
    "@value" : "standard (BE)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000263"
  }, {
    "@id" : "_:genid1075"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@value" : "Abschlussorientierter Standard (BE)"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "competence is a competence item, which expresses a capability an individuum already inheres or aquires throughout a learning process"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001448",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Thema (BE)"
  }, {
    "@language" : "en",
    "@value" : "topic (BE)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid1079"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A concrete topic of school teaching that can be taught through particular learning content."
  }, {
    "@language" : "de",
    "@value" : "Ein konkretes Thema des Unterricht, das durch Lerninhalte vermittelt werden kann."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001449",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Themenfeld (BE)"
  }, {
    "@language" : "en",
    "@value" : "topic area (BE)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid1083"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@value" : "Themenbereich (BE)"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A topic area includes one or more topics that are subject of teaching."
  }, {
    "@language" : "de",
    "@value" : "Ein Themenfeld umfasst ein oder meherere Themen die im Unterricht behandelt werden."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001450",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Zusatzmaterial (BE)"
  }, {
    "@language" : "en",
    "@value" : "additional material (BE)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid1087"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Documents which refer to additional resources to learn with."
  }, {
    "@language" : "de",
    "@value" : "Dokumente, die auf zusätzliche Ressourcen zum Lernen verweisen."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001451",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "exercise (BE)"
  }, {
    "@language" : "de",
    "@value" : "Übung (BE)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0001441"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A concrete action that helps to learn a skill."
  }, {
    "@language" : "de",
    "@value" : "Eine konkrete Maßnahme, die dazu beiträgt, eine Kompetenz zu erlernen."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001459",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Kompetenzbereich (BE)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
