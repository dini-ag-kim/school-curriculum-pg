    "@language" : "en",
    "@value" : "Class of the designations of the German federal states whose ministries of education and cultural affairs are responsible for the curricula."
  }, {
    "@language" : "de",
    "@value" : "Klasse der Bezeichnungen der deutschen Bundesländer, deren Kultusministerien für die Lehrpläne zuständig ist."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
