  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart des Sekundarbereichs I mit mehreren Bildungsgängen, die zu unterschiedlichen Abschlüssen führen (Erster Schulabschluss, Mittlerer Schulabschluss, Berechtigung zum Übergang in die gymnasiale Oberstufe). Bei der Form der Gesamtschule werden alle Lernenden, unabhängig vom angestrebten Abschluss, in einem Klassenverband unterrichtet."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
