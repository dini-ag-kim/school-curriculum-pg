}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000835",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Das “Gymnasialniveau Sek II” ist ein “Bildungsgangniveau”, welches das Niveau des gymnasialen Bildungsgangs im Sekundarbereich II beschreibt und somit meistens die Jahrgangsstufen 11-13 umfasst.\nEs beschreibt in welcher Tiefe und mit welchem Anspruch die Lerninhalte und Kompetenzen innerhalb dieses Bildungsgangs behandelt werden."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gymnasialniveau Sek II"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000028"
  } ]
}, {
