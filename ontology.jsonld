  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b continuant part of c =Def b and c are continuants & there is some time t such that b and c exist at t & b continuant part of c at t"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Milk teeth continuant part of human; surgically removed tumour continuant part of organism"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "continuant part of at some time"
  } ]
