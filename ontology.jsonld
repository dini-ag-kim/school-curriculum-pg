  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A competence area is a competence item, which groups specific competences together."
  }, {
    "@language" : "de",
    "@value" : "Ein Kompetenzbereich ist zu verstehen als ein Kompetenzelement, das bestimmte Kompetenzen zu einer Gruppe zusammenfasst."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "dealing with expertise"
  }, {
    "@language" : "en",
    "@value" : "problem solving"
  }, {
    "@language" : "en",
    "@value" : "reading competencies"
  } ]
