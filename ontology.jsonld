    "@language" : "en",
    "@value" : "Relates an entity in the ontology to the name of the variable that is used to represent it in the code that generates the BFO OWL file from the lispy specification."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000232" : [ {
