  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000530",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Ein Grundkursniveau ist ein “Fachniveau” im gymnasialen Bildungsgang der Sekundarstufe II, das Inhalte und Kompetenzen auf einem grundlegenden Anforderungsniveau vermittelt.\nEs beschreibt in welcher Tiefe und mit welchem Anspruch die Lerninhalte und Kompetenzen innerhalb eines Fachs behandelt werden."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Grundkursniveau"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000265"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000531",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Ein Leistungskursniveau ist ein “Fachniveau” im gymnasialen Bildungsgang der Sekundarstufe II, das Inhalte und Kompetenzen auf einem vertieften Anforderungsniveau vermittelt.\nEs beschreibt in welcher Tiefe und mit welchem Anspruch die Lerninhalte und Kompetenzen innerhalb eines Fachs behandelt werden."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Leistungskursniveau"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000265"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000536",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Lehrplan Element bezogen auf die Vorgaben der KMK Bildungsstandards"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Element (Bista)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000261"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000537",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Wird verwendet, um Etwas einem Fach oder einem Fach mit besonderem \"Bezug\" (z.B. Zweite-Fremdsprache) zuzuordnen."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "hat Schulfach"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid141"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000024"
  } ],
  "http://www.w3.org/2002/07/owl#propertyChainAxiom" : [ {
    "@list" : [ {
      "@id" : "https://w3id.org/lehrplan/ontology/LP_0000537"
    }, {
      "@id" : "https://w3id.org/lehrplan/ontology/LP_0000537"
    } ]
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "wird üblicherweise am Lehrplan verwendet; kann ggf. auch an Kompetenzbereichen/Kompetenzspezifikation bzw. Themenbereichen/Themen verwendet werden, z.B. bei Lehrplänene die sich auf mehrere Fächer beziehen"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "de",
    "@value" : "Gegeben sind:\n\n:sf_1 a :Schulfach .\n:sf_1 sameAs ex:Englisch .\n\nBspl 1: \"Lehrplanelement :lpe_1 bezieht sich auf Schulfach Englisch\"\n\n:lpe_1 :hat_schulfach :sf_1 .\n\nBspl 2: \"Lehrplanelement :lpe_1 bezieht sich auf Schulfach Englisch als Zweite-Fremdsprache\"\n\n:lpe_2 :hat_schulfach :bezug_1 .\n:bezug_1 :hat_schulfach :sf_1 .\n:bezug_1 a :Zweite_Fremdsprache .\n\nAnmerkung: Durch die Property Chain wird in Beispiel 2 durch den Reasoner das folgende Tripel automatisch ergänzt:\n\n:lpe_2 :hat_schulfach :sf_1 ."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000540",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Ein “Schulfachbezug” ist eine “Informationseinheit” und gibt die Funktion und Spezifikation eines “Schulfachs”  in einem bestimmten Kontext an.\nBeispiele für “Schulfachbezug” sind “Erste Fremdsprache”, “Pflichtfach” oder “Wahlfach”."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Schulfachbezug"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000030"
  }, {
    "@id" : "_:genid755"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "de",
    "@value" : "Die Bezeichnung Rolle war nicht günstig gewählt, da sie mit bfo:role verwechselt werden kann."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "siehe Property https://w3id.org/lehrplan/ontology/LP_0000537"
  } ]
}, {
