  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000114",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart, die die Jahrgangsstufen 1-4 in allen Bundesländern außer Berlin und Brandenburg abdeckt und die Primarstufe umfasst. In Berlin und Brandenburg umfasst die Grundschule die Jahrgangsstufen 1-6."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Grundschule"
  } ],
