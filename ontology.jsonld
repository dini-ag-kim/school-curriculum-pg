}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000529",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000531"
  }, {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0002098"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
