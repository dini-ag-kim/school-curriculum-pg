  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Materialbeschreibungsfunktion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000493"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000482",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Elemente, die diese Funktion inne haben, strukturieren die Lehrpläne."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Strukturierungsfunktion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000478"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "de",
    "@value" : "Überschriften, Kapitel, Themenfelder, Kompetenzbereiche"
  } ]
}, {
