}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002005",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Eine “Mittelstufenschule” ist eine “Schulart” in HE, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\n- Schulstufe: Sekundarbereich I\n- Jahrgangsstufen: 5-10\n- Abschlüsse: Erster und Mittlerer Schulabschluss\n- Besonderheiten: der praxisorientierte Bildungsgang führt zum Ersten Schulabschluss, der mittlere Bildungsgang führt zum Mittleren Schulabschluss; Jahrgangsstufen 5-7 sind Aufbaustufe"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Mittelstufenschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002008",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Eine “Verbundene Haupt- und Realschule” ist eine “Schulart” in HE, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\n- Schulstufe: Sekundarbereich I\n- Jahrgangsstufen: 5-10\n- Abschlüsse: Erster und Mittlere Schulabschluss"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Verbundene Haupt- und Realschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002012",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Eine \"Kooperative Gesamtschule” ist eine “Schulart” in HE, MV, NI, ST und TH, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\nSchulstufe: Sekundarbereich I und Sekundarbereich II\n- Jahrgangsstufen: 5-13\n- Abschlüsse: Erster und Mittlerer Schulabschluss und die Allgemeine Hochschulreife\n- Besonderheiten: verschiedene Schularten sind organisatorisch zu einer Schule verbunden, Klassen sind nach Bildungsgängen getrennt"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Kooperative Gesamtschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ],
  "https://w3id.org/lehrplan/ontology/LP_0000141" : [ {
    "@id" : "https://w3id.org/kim/schularten/s05"
  } ]
}, {
