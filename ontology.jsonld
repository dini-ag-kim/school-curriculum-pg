  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@value" : "Methodische Hinweise und Verknüpfungshinweise (MV)"
  }, {
    "@value" : "Verknüpfungen (MV)"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002150",
