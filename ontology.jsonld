    "@value" : "b proper continuant part of c at some time =Def for some time t (b continuant part of c at t & not (c continuant part of b at t)"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "proper continuant part of at some time"
