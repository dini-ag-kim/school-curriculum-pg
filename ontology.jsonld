  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Themenfeldfunktion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000482"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "de",
    "@value" : "Ein Lehrplanelement, das diese Funtion inne hat, beschreibt einen Thema. Einem Thema kann einem Themenfeld oder anderen Themen untergeordnet werden."
  }, {
    "@language" : "de",
    "@value" : "Ein Lehrplanelement, das diese Funtion inne hat, beschreibt einen Themenfeld. Einem Themenfeld können Themen untergeordnet werden."
  } ]
