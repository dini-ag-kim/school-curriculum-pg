  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000238",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Eine “Oberschule” ist eine “Schulart” in  BB, HB, NI und SN, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\n- Schulstufe: Sekundarbereich I, in SN auch Primar, in HB auch Sekundarbereich II\n- Jahrgangsstufen: 5-10, in SN 1-10 (s. Besonderheiten), in HB 5-13 \n- Abschlüsse: Erster und Mittlerer Schulabschluss, in HB auch die Allgemeine Hochschulreife\n- Besonderheiten: Oberschule + in SN mit verbundener Grundschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Oberschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ],
  "https://w3id.org/lehrplan/ontology/LP_0000141" : [ {
    "@id" : "https://w3id.org/kim/schularten/s07"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000240",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Eine “Gesamtschule” ist eine “Schulart” in BB und NW, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\nSchulstufe: Sekundarbereich I und Sekundarbereich II\n- Jahrgangsstufen: 5-13\n- Abschlüsse: Erster und Mittlerer Schulabschluss und die Allgemeine Hochschulreife\n- Besonderheiten: in BB ggf. Leistungs- und Begabungsklasse ab Jahrgangsstufe 5"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gesamtschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ],
  "https://w3id.org/lehrplan/ontology/LP_0000141" : [ {
