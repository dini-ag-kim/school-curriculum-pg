  }, {
    "@id" : "_:genid1629"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "kommt vor im Fach Mathematik im Gymnasium Sek I"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002241",
