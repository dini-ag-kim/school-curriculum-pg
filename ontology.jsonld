}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000076",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Allgemeine Hochschulreife"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid322"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "de",
    "@value" : "Die “Allgemeine Hochschulreife” ist ein “Schulabschluss” und der höchste allgemeinbildende Schulabschluss. Er wird je nach Bundesland und Schulart nach der Jahrgangsstufe 12 oder 13 verliehen und berechtigt zum Studium an einer Hochschule. Die “Allgemeine Hochschulreife” wird synonym zum Begriff Abitur verwendet."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000077",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Fachabitur"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000019"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000078",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Der “Mittlere Schulabschluss” ist ein “Schulabschluss” und ein allgemeinbildender Schulabschluss. Er wird nach der Jahrgangsstufe 10 verliehen. In den Bundesländern trägt der “Mittlere Schulabschluss” verschiedene Bezeichnungen:\n- Mittlerer Schulabschluss (BY, BE, HB, HH, SH, BW, NW)\n- Mittlere Reife (MV)\n- Mittlerer Bildungsabschluss (SL)\n- Realschulabschluss (HE, NI, SN, ST, TH)\n- Berechtigung zum Besuch der gymnasialen Oberstufe (BB, NW)\n- Fachoberschulreife (BB)\n- Qualifizierter Sekundarabschluss I (RP)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Mittlerer Schulabschluss"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid326"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000079",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Der “Erste Schulabschluss” ist ein “Schulabschluss” und ist der erste allgemeinbildende Schulabschluss. Er wird je nach Bundesland und Schulart nach der Jahrgangsstufe 9 oder 10 verliehen. In den Bundesländern trägt der “Erste Schulabschluss” verschiedene Bezeichnungen:\n- Erster allgemeinbildender Schulabschluss (HH, NW, SH)\n- Hauptschulabschluss (BW, HE, NI, SL, SN, ST, TH)\n- Berufsbildungsreife (BB, BE, HB)\n- Berufsreife (MV, RP)\n- Erfolgreicher Abschluss der Mittelschule (BY)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Erster Schulabschluss"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid330"
  } ]
}, {
