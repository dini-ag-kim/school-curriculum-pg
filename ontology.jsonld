}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0001015",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A \"CE-Fragment\" is a \"Curriculares Element\" with a structuring function. It is used to delineate a specific context within a curriculum or educational standard, such as chapters or thematic divisions."
  }, {
    "@value" : "Ein “CE-Fragment” ist ein “Curriculares Element\" mit einer strukturierenden Funktion. Es dient zur Abgrenzung eines bestimmten Kontextes innerhalb eines Lehrplans oder Bildungsstandards, wie etwa Kapiteln oder thematischen Gliederungen."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "CE-Fragment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000261"
  }, {
    "@id" : "_:genid996"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid992"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "Mögliche Properties:\n- Titel\n- Ordnungsnummer\n- Schulfach\n- Schulart / Bildungsgang\n- Schulstufe\n\nMeistens handelt es sich hierbei um Überschriften von Kapiteln in Lehrplänen oder Bildungsstandards."
  } ]
}, {
