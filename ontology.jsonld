}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002115",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "\"Lernziele und Lerninhalte sind verbindlich. Sie kennzeichnen grundlegende Anforderungen in den Bereichen Wissenserwerb, Kompetenzentwicklung und Werteorientierung.\n\nIm Sinne der Vergleichbarkeit von Lernprozessen erfolgt die Beschreibung der Lernziele in der Regel unter Verwendung einheitlicher Begriffe. Diese verdeutlichen bei zunehmendem Umfang und steigender Komplexität der Lernanforderungen didaktische Schwerpunktsetzungen für die unterrichtliche Erarbeitung der Lerninhalte.\""
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Lernziele und Lerninhalte (SN)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000263"
  }, {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000332"
  }, {
    "@id" : "_:genid4067"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002116",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "\"Bemerkungen haben Empfehlungscharakter. Gegenstand der Bemerkungen sind inhaltliche Erläuterungen, Hinweise auf geeignete Lehr- und Lernmethoden und Beispiele für Möglichkeiten einer differenzierten Förderung der Schüler. Sie umfassen Bezüge zu Lernzielen und Lerninhalten des gleichen Faches, zu anderen Fächern und zu den überfachlichen Bildungs- und Erziehungszielen.\""
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Bemerkungen (SN)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid4073"
  } ]
}, {
