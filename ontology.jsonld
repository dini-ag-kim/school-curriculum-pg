  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A concrete action that helps to learn a skill."
  }, {
    "@language" : "de",
    "@value" : "Eine konkrete Maßnahme, die dazu beiträgt, eine Kompetenz zu erlernen."
  } ]
