  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "de",
    "@value" : "Die Bezeichnung Rolle war nicht günstig gewählt, da sie mit bfo:role verwechselt werden kann."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "siehe Property https://w3id.org/lehrplan/ontology/LP_0000537"
  } ]
