}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000274",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart des Sekundarbereichs I und II mit mehreren Bildungsgängen, die zu unterschiedlichen Abschlüssen führen (Hauptschulabschluss, Mittlerer Schulabschluss, Abitur). Sie umfasst die Jahrgangsstufen 5-13, je nach Bildungsgang."
  } ],
