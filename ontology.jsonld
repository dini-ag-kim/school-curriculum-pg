    "@value" : "Abschlussorientierter Standard (BB)"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "competence is a competence item, which expresses a capability an individuum already inheres or aquires throughout a learning process"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000448",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Thema (BB)"
  }, {
    "@language" : "en",
    "@value" : "topic (BB)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0002106"
  }, {
    "@id" : "_:genid2735"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A concrete topic of school teaching that can be taught through particular learning content."
  }, {
    "@language" : "de",
    "@value" : "Ein konkretes Thema des Unterricht, das durch Lerninhalte vermittelt werden kann."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000449",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Themenfeld (BB)"
  }, {
    "@language" : "en",
    "@value" : "topic area (BB)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0002106"
  }, {
    "@id" : "_:genid2739"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@value" : "Themenbereich (BB)"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A topic area includes one or more topics that are subject of teaching."
  }, {
    "@language" : "de",
    "@value" : "Ein Themenfeld umfasst ein oder meherere Themen die im Unterricht behandelt werden."
