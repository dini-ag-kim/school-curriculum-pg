  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Ein “Gymnasium” ist eine “Schulart” in allen Bundesländern, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\n- Schulstufe: Sekundarbereich I und II\n- Jahrgangsstufen: 5-12/13, in BE und BB 7-12/13\n- Abschlüsse: Erster und Mittlerer Schulabschluss und die Allgemeine Hochschulreife\n- Besonderheiten: in BE ggf. Schnelllernerklassen ab 5, in BB ggf. Leistungs- und Begabungsklasse ab Jahrgangsstufe 5"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gymnasium"
  } ],
