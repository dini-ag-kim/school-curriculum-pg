  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000345",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Teilthema (RP)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000328"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "wird nicht so im LP benannt. Löschen?"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000346",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
