}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000319",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Eine “Regelschule” ist eine “Schulart” TH, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\n- Schulstufe: Sekundarbereich I\n- Jahrgangsstufen: 5-10\n- Abschlüsse: Erster und Mittlerer Schulabschluss"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Regelschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000328",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Thema (RP)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid643"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "kommt in Mathematik Sek II vor.\ns. außerdem Moderne Fremdsprache - Englisch Sek I."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000332",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A “CE-Lerninhalt” is a “curricular element” that describes a learning content in the form of specific topics. The “CE-Lerninhalt” provides the content basis for the preparation of school lessons.\nCompetencies can be acquired on the basis of the “CE-Lerninhalt”."
  }, {
    "@language" : "de",
    "@value" : "Ein “CE-Lerninhalt” ist ein “Curriculares Element\", das einen Lerninhalt in Form konkreter Themen beschreibt. Der „CE-Lerninhalt“ liefert die inhaltliche Basis für die Gestaltung des Unterrichts.\nAnhand des \"CE-Lerninhalts\" können Kompetenzen erworben werden.\n\nBeispiel:\n\nCE-Kompetenzspezifikation: Die Schülerinnen und Schüler setzen sich auf der Grundlage ihrer Kenntnisse bewusst mit der englischen Sprache und den mit ihr verbundenen Kulturräumen auseinander.\nCE-Lerninhalt: Kanada: Einblicke in Geographie und Gesellschaft; Inuit/First People"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "CE-Lerninhalt"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000261"
  }, {
    "@id" : "_:genid651"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid647"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000336",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Fachbezogene Kompetenzspezifikation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000263"
  }, {
    "@id" : "_:genid656"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid652"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "Bezieht sich auf ein bestimmtes Fach"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000337",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Fach- und Lernbereichsübergreifende Kompetenzspezifikation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000263"
  }, {
    "@id" : "_:genid661"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid657"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "de",
    "@value" : "Bezüglich mehrere Fächer bzw. eines Fachverbund"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000339",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "RP"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gemeinschaftskunde"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000005"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid662"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000340",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000005"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Sozialkunde (Schulfach)"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000341",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Ist eine Schulstufe des Gymnasiums, die aber auch an anderen Schularten eingerichtet werden kann. Sie umfasst die Sekundarstufe II. Sie deckt die Jahrgangsstufen 11-13 oder 10-12 ab, je nach Land und Schulart. (Allgemeinbildender Bildungsgang mit Abiturprüfung als Abschluss, der zur Allgemeinen Hochschulreife führt.)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gymnasiale Oberstufe"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000020"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "Axiom entfernt: \n\nequivalenClass: Schulart and (ermöglicht_abschluss some 'Allgemeine Hochschulreife')"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000342",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Lehrplan Element bezogen auf den Lehrplan von Rheinland-Pfalz"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Element (RP)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000261"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid666"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000343",
