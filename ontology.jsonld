  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000349",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A “CE-Bereich” is a “Curriculares Element”.\nA “CE-Bereich” can be superordinate or subordinate to other “CE-Bereichen”.\nThe element serves to structure curricula and educational standards by grouping “CE-Kompetenzspezifikationen” and/or “CE-Lerninhalte” under a common content focus, which is defined by the “CE-Bereich”."
  }, {
    "@language" : "de",
    "@value" : "Ein “CE-Bereich” ist ein “Curriculares Element”.\nEin “CE-Bereich” kann anderen “CE-Bereichen” über- oder untergeordnet sein.\nDas Element dient der Gliederung von Lehrplänen und Bildungsstandards, indem es “CE-Kompetenzspezifikationen” und/oder “CE-Lerninhalte” unter einem gemeinsamen inhaltlichen Fokus zusammenfasst, der durch den “CE-Bereich” definiert wird."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "CE-Bereich"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000261"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "Mögliche Properties:\n- Titel\n- Ordnungsnummer\n- Beschreibung\n- Stundenzahl\n- Jahrgangsstufe"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000350",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
