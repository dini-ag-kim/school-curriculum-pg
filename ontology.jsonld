}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000845",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "CE-Progressionsstufe"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000261"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "de",
    "@value" : "Die Progresssion ist Teil einer Kompetenz-Spezifikation oder eines Lerninhalts. Sie beschreibt genau den Teil, der je nach Niveau variabel ist. Jede Progessionssstufe hat eine eigene Beziehung zu einer Niveauspezifikation."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "de",
    "@value" : "Wenn die Komptenz \"Lesen\" ist, könnten Progressionen sein: \"Worte einzeln lesen\", \"Mit Hilfe (Finger, Stäbchen, Lineal) lesen.\", \"Flüssig lesen\""
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000851",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Niveauspezifikationsfunktion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000478"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000852",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A “CE-Hinweis”’ is a “Curriculares Element” that contains supplementary information or suggestions on a “CE-Bereich”, a “CE-Lerninhalt” or a “CE-Kompetenzspezifikation”. The “CE-Hinweis”’ is a recommendation. Examples:\n- practical or methodological recommendations\n- Recommendation on interdisciplinary connections\n- Suggestions or tips for implementation in the classroom\n- Suggestions for in-depth study\n- Differentiation suggestions"
  }, {
    "@language" : "de",
    "@value" : "Ein “CE-Hinweis” ist ein “Curriculares Element”, das ergänzende Informationen oder Anregungen zu einem “CE-Bereich”, einem “CE-Lerninhalt” oder einer “CE-Kompetenzspezifikation” beinhaltet. Der “CE-Hinweis” hat einen Empfehlungscharakter. Beispiele:\n- praktische oder methodische Empfehlungen\n- Empfehlung zu fachübergreifenden Verbindungen\n- Vorschläge oder Hinweise zur Umsetzung im Unterricht\n- Vertiefungsvorschläge\n- Differenzierungsvorschläge"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "CE-Hinweis"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000261"
  }, {
    "@id" : "_:genid935"
  }, {
    "@id" : "_:genid936"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid925"
  } ]
}, {
