}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000479",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Ein Element, das diese Funktion inne hat, beschreibt Kompetenzen, die SuS haben können oder eine Ausführung in der die Kompetenz angewandt wird."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Kompetenzbeschreibungsfunktion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000493"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "de",
    "@value" : "Ein Lehrplanelement das die Funktion inne hat das beschreibt z.B. \"Die SuS sollen Kompexen Zahlen addieren können\" oder \"über Konflikte sprechen\". Üblicherweise beginnt die Beschreibung mit \"Die SuS sollen .... \". Die Beschreibungen enthalten üblicherweise Operatoren."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000480",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Ein Element, das diese Funktion inne hat, beschreibt Inhalte, die im Unterricht vermittelt werden. Es beschreibt konkrete Themen oder Handlungsanweisungen zur Gestaltung des Unterrichts oder Mittel zum Erlangen von Kompetenzen."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Lerninhaltsbeschreibungsfunktion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000493"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000481",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Ein Element, das diese Funktion inne hat, beschreibt Materialien, die im Unterricht verwendet werden können."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Materialbeschreibungsfunktion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000493"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000482",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
