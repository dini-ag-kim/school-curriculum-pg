}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000121",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart des Sekundarbereichs I mit mehreren Bildungsgängen in Berlin, die zu unterschiedlichen Abschlüssen führen (Hauptschulabschluss, Mittlerer Schulabschluss, Berechtigung zum Übergang in die gymnasiale Oberstufe, Abitur). Die Integrierte Sekundarschule umfasst den Sekundarbereich I und II."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Integrierte Sekundarschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid222"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000122",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart, die Sekundarbereich I und II umfasst (in der Regel mit den Jahrgangsstufen 5-12 oder 13, Ausnahme BB: beginnend ab 7) und eine vertiefte allgemeine Bildung mit dem Ziel der Allgemeinen Hochschulreife vermittelt.  Je nach Bundesland können auf dem Bildungsgang zum Abitur auch der Erste - und Mittlere Schulabschluss erworben werden."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gymnasium"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ],
