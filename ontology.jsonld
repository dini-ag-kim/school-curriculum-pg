    "@id" : "http://purl.obolibrary.org/obo/RO_0000052"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0000085"
  } ]
}, {
