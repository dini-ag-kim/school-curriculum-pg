    "@id" : "_:genid3896"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "Hat Funktion Themenfeldbereich in Primarstufe, Trennung hier zwischen Kompetenzen und lerninhalten nicht klar."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002149",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
