}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000332",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Element, das einen Lerninhalt beschreibt. Die kleinste Einheit, die konkrete Themen oder Handlungsanweisungen zur Gestaltung des Unterrichts oder Mittel zum Erlangen von Kompetenzen beschreibt. Kann einer Kompetenz zugeordnet sein, kann aber auch alleine stehen."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "CE-Lerninhalt"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1803"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000335",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Fachniveaufunktion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000478"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000336",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Fachbezogene Kompetenz"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1807"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "Bezieht sich auf ein bestimmtes Fach"
  } ]
}, {
