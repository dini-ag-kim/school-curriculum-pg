}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0002012",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart des Sekundarbereichs I mit mehreren Bildungsgängen, die zu unterschiedlichen Abschlüssen führen (Erster Schulabschluss, Mittlerer Schulabschluss, Berechtigung zum Übergang in die gymnasiale Oberstufe). Die Form der Gesamtschule bedeutet, dass die verschiedenen Schulformen lediglich organisatorisch zu einer Schule verbunden sind, die Klassen also nach Bildungsgang aufgeteilt sind.\nDie Schulart Kooperative Gesamtschule gibt es in HE, MV, NI, ST und TH."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Kooperative Gesamtschule"
  } ],
