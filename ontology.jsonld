}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000537",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Wird verwendet, um Etwas einem Fach oder einem Fach mit besonderem \"Bezug\" (z.B. Zweite-Fremdsprache) zuzuordnen."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "hat_schulfach"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid3"
  } ],
  "http://www.w3.org/2002/07/owl#propertyChainAxiom" : [ {
    "@list" : [ {
      "@id" : "https://w3id.org/lehrplan/ontology/LP_0000537"
    }, {
      "@id" : "https://w3id.org/lehrplan/ontology/LP_0000537"
    } ]
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "de",
    "@value" : "Gegeben sind:\n\n:sf_1 a :Schulfach .\n:sf_1 sameAs ex:Englisch .\n\nBspl 1: \"Lehrplanelement :lpe_1 bezieht sich auf Schulfach Englisch\"\n\n:lpe_1 :hat_schulfach :sf_1 .\n\nBspl 2: \"Lehrplanelement :lpe_1 bezieht sich auf Schulfach Englisch als Zweite-Fremdsprache\"\n\n:lpe_2 :hat_schulfach :bezug_1 .\n:bezug_1 :hat_schulfach :sf_1 .\n:bezug_1 a :Zweite_Fremdsprache .\n\nAnmerkung: Durch die Property Chain wird in Beispiel 2 durch den Reasoner das folgende Tripel automatisch ergänzt:\n\n:lpe_2 :hat_schulfach :sf_1 ."
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000540",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Ermöglicht den Bezug auf ein Schulfach in einen oder mehreren bestimmten Kontexten."
