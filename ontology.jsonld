  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart in Hamburg des Sekundarbereichs I und II mit mehreren Bildungsgängen, die zu unterschiedlichen Abschlüssen führen (Hauptschulabschluss, Mittlerer Schulabschluss, Abitur). Sie umfasst die Jahrgangsstufen 5-13, je nach Bildungsgang."
  } ],
