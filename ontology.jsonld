  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@value" : "Frage: wie unterschiedet siech die integrierte sekundarschule mit 11-12 vopnd er mit 11-13 jahren? sind das die schnelllerner?"
  } ]
