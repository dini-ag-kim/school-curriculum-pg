  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart im Sekundarbereich I, in der Regel mit den Jahrgangsstufen 5-10, die eine erweiterte allgemeine Bildung vermittelt und den Übergang in berufs- und studienqualifizierende Bildungsgänge des Sekundarbereichs II eröffnet. Mit bestandener Prüfung wird der Mittlere Schulabschluss erteilt.\nDie Schulart Realschule gibt es in BW, BY, HE, NI und NW."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/"
  } ],
