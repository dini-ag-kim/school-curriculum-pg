}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000832",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Das “Realschulniveu” ist ein “Bildungsgangniveau”, welches das Niveau des\nRealschulbildungsgangs beschreibt. \nEs beschreibt in welcher Tiefe und mit welchem Anspruch die Lerninhalte und Kompetenzen innerhalb dieses Bildungsgangs behandelt werden."
  } ],
