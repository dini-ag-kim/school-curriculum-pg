  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Eine “Werkschule” ist eine “Schulart” in HB, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\n- Schulstufe: Sekundarbereich I\n- Jahrgangsstufen: 5-11\n- Abschlüsse: Erster und Mittlerer Schulabschluss\n- Besonderheiten: Jede Werkschule hat sich auf bestimmte Dienstleistungen und Produktionen spezialisiert"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Werkschule"
  } ],
