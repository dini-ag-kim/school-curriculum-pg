}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000238",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart des Sekundarbereichs I in Brandenburg, Niedersachsen und Sachsen an der die Bildungsgänge von Hauptschule und Realschule angeboten werden. Schulart in Bremen des Sekundarbereichs I und II mit mehreren Bildungsgängen, die zu unterschiedlichen Abschlüssen führen (Hauptschulabschluss, Mittlerer Schulabschluss, Abitur)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Oberschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1043"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000239",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Oberschule Sek I (BB)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid1047"
  } ]
}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000240",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart des Sekundarbereichs I mit mehreren Bildungsgängen, die zu unterschiedlichen Abschlüssen führen (Erster Schulabschluss, Mittlerer Schulabschluss, Berechtigung zum Übergang in die gymnasiale Oberstufe). Gesamtschulen können auch den Sekundarbereich II in Form der gymnasialen Oberstufe umfassen. Die Gesamtschule gibt es zusätzlich als integrierte und kooperative Form."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gesamtschule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/lehrplan/ontology/LP_0000111"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1069"
  } ]
}, {
