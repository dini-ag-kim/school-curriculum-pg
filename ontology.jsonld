  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Schulart, die schulstufenübergreifend ist. Sie umfasst die Jahrgangsstufen 1-10 oder 13, je nach angestrebtem Abschluss. Je nach Bundesland kann die Schulart auch erst beginnend ab Sekundarstufe I sein."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gemeinschaftsschule"
  } ],
