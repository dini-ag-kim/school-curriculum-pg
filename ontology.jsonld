}, {
  "@id" : "https://w3id.org/lehrplan/ontology/LP_0000292",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "de",
    "@value" : "Eine \"Integrierte Gesamtschule” ist eine “Schulart” in HE, MV, NI, RP, ST und TH, die sich durch folgende Merkmale von anderen Schularten unterscheidet:\nSchulstufe: Sekundarbereich I und Sekundarbereich II\n- Jahrgangsstufen: 5-13\n- Abschlüsse: Erster und Mittlerer Schulabschluss und die Allgemeine Hochschulreife\n- Besonderheiten: unabhängig vom angestrebten Abschluss werden alle Lernenden in einem Klassenverband unterrichtet"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Integrierte Gesamtschule"
  } ],
